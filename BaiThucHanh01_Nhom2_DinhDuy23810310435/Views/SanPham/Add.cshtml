@model BaiThucHanh01_Nhom2_DinhDuy23810310435.Models.SanPham
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Thêm mới sản phẩm - Nguyễn Đình Duy</title>
    <link rel="stylesheet" href="~/css/form.css" />
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
    <div class="form-container">
        <a href="/SanPham/Info" class="btn-back"><i data-lucide="arrow-left" width="18"></i> Quay lại danh sách</a>

        <h2 class="form-title">THÊM SẢN PHẨM MỚI</h2>

        <form asp-action="Add" method="post" enctype="multipart/form-data">
            @if (ViewData.ModelState.IsValid)
             {
                <div asp-validation-summary="All" style="color: #d93838; font-weight: bold; margin-bottom: 15px; padding: 10px; border: 1px dashed red; background: #ffe6e6;"></div>

             }

            <div class="form-group">
                <label>Tên sản phẩm *</label>
                <input asp-for="TenSanPham" class="form-control" required />
            </div>

            <div class="form-group">
                <label>Danh mục *</label>
                <select asp-for="DanhMucId" asp-items="@ViewBag.DanhMucs" class="form-control" required>
                    <option value="">-- Chọn danh mục --</option>
                </select>
            </div>

            <div class="form-group">
                <label>Giá bán ($) *</label>
                <input asp-for="GiaBan" type="number" step="0.01" class="form-control" required />
            </div>

            <div class="form-group">
                <label>Giá gốc ($) (Không bắt buộc)</label>
                <input asp-for="GiaGoc" type="number" step="0.01" class="form-control" />
            </div>

            <div class="form-group">
                <label>% Giảm giá (Không bắt buộc)</label>
                <input asp-for="PhanTramGiam" type="number" class="form-control" />
            </div>

            <div class="form-group" style="background: #fdfdfd; padding: 15px; border-radius: 8px; border: 2px dashed #ccc;">
                <label style="color: #d93838; font-weight: bold; margin-bottom: 10px; display: block;">
                    <i data-lucide="image" width="18" style="vertical-align: middle;"></i> Tùy chọn Ảnh Sản Phẩm (Chọn 1 trong 2)
                </label>

                <label>Cách 1: Nhập đường dẫn thủ công (VD: /lib/product-1.png)</label>
                <input asp-for="DuongDanAnh" class="form-control" style="margin-bottom: 15px;" placeholder="/lib/..." />

                <div style="text-align: center; color: #888; font-size: 13px; margin-bottom: 15px; font-weight: bold;">--- HOẶC ---</div>

                <label>Cách 2: Tải ảnh từ máy tính (Sẽ ưu tiên cách này nếu bạn chọn file)</label>
                <input type="file" name="hinhAnh" class="form-control" accept="image/*" />
            </div>

            <div class="form-group">
                <label>Phân loại hiển thị (Tabs):</label>
                <div class="checkbox-group">
                    <label><input asp-for="IsNewProduct" type="checkbox" /> New Product</label>
                    <label><input asp-for="IsOnSale" type="checkbox" /> On Sale</label>
                    <label><input asp-for="IsFeatureProduct" type="checkbox" /> Featured</label>
                </div>
            </div>

            <button type="submit" class="btn-submit">LƯU SẢN PHẨM</button>
        </form>
    </div>

    <footer>Dự án E-commerce MVC | Phát triển bởi: <strong>Nguyễn Đình Duy</strong> (Nhóm 2)</footer>
    <script>lucide.createIcons();</script>
</body>
</html>