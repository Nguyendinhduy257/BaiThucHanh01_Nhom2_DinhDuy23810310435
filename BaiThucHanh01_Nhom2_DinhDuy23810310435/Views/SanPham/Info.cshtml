@model IEnumerable<BaiThucHanh01_Nhom2_DinhDuy23810310435.Models.SanPham>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = null;

    // Xử lý class cho Tabs
    string tabNewClass = "tab";
    string tabSaleClass = "tab";
    string tabFeaturedClass = "tab";

    if (ViewBag.ActiveTab == "sale") tabSaleClass = "tab active";
    else if (ViewBag.ActiveTab == "featured") tabFeaturedClass = "tab active";
    else tabNewClass = "tab active";

    // Lấy danh sách danh mục để làm Selectbox (Đã chuẩn bị ở Controller)
    var danhMucs = ViewBag.DanhMucs as List<BaiThucHanh01_Nhom2_DinhDuy23810310435.Models.DanhMuc>;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách sản phẩm - VIP Pro Edition</title>

    <link rel="stylesheet" href="~/css/info.css" />

    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>

    <div class="container">

        <div class="tabs">
            <a href="/SanPham/Info?tab=new&page=1" class="@tabNewClass">NEW PRODUCT</a>
            <a href="/SanPham/Info?tab=sale&page=1" class="@tabSaleClass">ON SALE</a>
            <a href="/SanPham/Info?tab=featured&page=1" class="@tabFeaturedClass">FEATURED PRODUCT</a>
        </div>

        <form method="get" action="/SanPham/Info" class="toolbar">
            <input type="hidden" name="tab" value="@ViewBag.ActiveTab" />

            <div class="filter-group">
                <input type="text" name="searchName" value="@ViewBag.SearchName"
                       placeholder="Tìm kiếm sản phẩm..." class="fancy-input" />

                <select name="danhMucId" class="fancy-input" style="cursor: pointer;">
                    <option value="">-- Tất cả danh mục --</option>
                    @if (danhMucs != null)
                    {
                        foreach (var dm in danhMucs)
                        {
                            if (ViewBag.CurrentDanhMuc == dm.Id)
                            {
                                <option value="@dm.Id" selected>@dm.NameVN</option>
                            }
                            else
                            {
                                <option value="@dm.Id">@dm.NameVN</option>
                            }
                        }
                    }
                </select>

                <button type="submit" class="btn-fancy">
                    <i data-lucide="filter" width="18"></i> Lọc
                </button>
                <a href="/SanPham/Info?tab=@ViewBag.ActiveTab" class="btn-outline">Reset</a>
            </div>

            <div style="display: flex; gap: 10px;">
                <a href="/DanhMuc/Index" class="btn-outline" style="text-decoration: none;">
                    <i data-lucide="folder-tree" width="18"></i> Quản lý Danh Mục
                </a>

                <a href="/SanPham/Add" class="btn-fancy btn-add-new" style="text-decoration: none;">
                    <i data-lucide="plus-circle" width="18"></i> Thêm Sản Phẩm
                </a>
            </div>
        </form>

        <div class="product-grid" id="productGrid">
            @if (Model != null && Model.Any())
            {
                foreach (var sp in Model)
                {
                    <div class="product-card">

                        @if (sp.PhanTramGiam.HasValue && sp.PhanTramGiam > 0)
                        {
                            <div class="badge-discount">-@sp.PhanTramGiam%</div>
                        }

                        <div class="icon-actions">
                            <button class="icon-btn btn-heart" title="Yêu thích" onclick="toggleLike(this)">
                                <i data-lucide="heart" width="18"></i>
                            </button>

                            <a href="/SanPham/Edit/@sp.Id" class="icon-btn btn-edit" title="Chỉnh sửa (ID: @sp.Id)">
                                <i data-lucide="edit" width="18"></i>
                            </a>

                            <a href="/SanPham/Delete/@sp.Id"
                               class="icon-btn btn-edit btn-danger-icon" title="Xóa (ID: @sp.Id)"
                               onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm [ @sp.TenSanPham ] này không? Bay luôn cả ảnh liên quan đấy nhé!');">
                                <i data-lucide="trash-2" width="18"></i>
                            </a>
                        </div>

                        <img src="@sp.DuongDanAnh" alt="@sp.TenSanPham" class="product-image"
                             onerror="this.src='https://via.placeholder.com/250x250?text=No+Image'" />

                        <a href="/SanPham/Add" class="add-to-cart">ADD TO CART</a>

                        <div class="price-wrapper">
                            <span class="price">$@sp.GiaBan.ToString("0.00")</span>
                            @if (sp.GiaGoc.HasValue)
                            {
                                <span class="old-price">$@sp.GiaGoc.Value.ToString("0.00")</span>
                            }
                        </div>

                        <div class="product-name">
                            <strong>@sp.TenSanPham</strong> <br />
                            <span style="font-size:12px; color:#999;">
                                ID: @sp.Id | Danh mục: @(sp.DanhMuc?.NameVN ?? "Chưa phân loại")
                            </span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="grid-column: 1 / -1; text-align: center; padding: 50px; background: #fff; border-radius: 16px;">
                    <i data-lucide="package-open" width="48" style="color: #ccc; margin-bottom: 15px;"></i>
                    <h3 style="color: #555;">Không tìm thấy sản phẩm nào!</h3>
                    <p style="color: #888;">Sếp thử đổi bộ lọc hoặc thêm sản phẩm mới xem sao.</p>
                </div>
            }
        </div>

        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            <div class="pagination">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="/SanPham/Info?tab=@ViewBag.ActiveTab&page=@(ViewBag.CurrentPage - 1)&searchName=@ViewBag.SearchName&danhMucId=@ViewBag.CurrentDanhMuc">
                        <i data-lucide="chevron-left" width="18"></i>
                    </a>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    if (i == ViewBag.CurrentPage)
                    {
                        <a href="#" class="active">@i</a>
                    }
                    else
                    {
                        <a href="/SanPham/Info?tab=@ViewBag.ActiveTab&page=@i&searchName=@ViewBag.SearchName&danhMucId=@ViewBag.CurrentDanhMuc">@i</a>
                    }
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="/SanPham/Info?tab=@ViewBag.ActiveTab&page=@(ViewBag.CurrentPage + 1)&searchName=@ViewBag.SearchName&danhMucId=@ViewBag.CurrentDanhMuc">
                        <i data-lucide="chevron-right" width="18"></i>
                    </a>
                }
            </div>
        }

    </div>

    <footer>
        Dự án E-commerce MVC | Phát triển bởi: <strong>Nguyễn Đình Duy</strong> (Nhóm 2)
    </footer>

    <script src="~/js/info.js"></script>
</body>
</html>